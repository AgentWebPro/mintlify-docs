{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "AgentWeb",
  "description": "AgentWeb Documentation",
  "colors": {
    "primary": "#7A6999",
    "light": "#ECAC5F",
    "dark": "#1B2549"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://app.agentweb.pro"
  },
  "fonts": {
    "family": "Inter"
  },
  "appearance": {
    "default": "light"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "User Guide",
        "groups": [
          {
            "group": "Onboarding",
            "icon": "rocket",
            "pages": [
              "index",
              "onboarding/brand-onboarding",
              "onboarding/organization-sharing"
            ]
          },
          {
            "group": "User Guide",
            "icon": "book-open",
            "pages": [
              "user-guide/agent-mode",
              "user-guide/brand",
              "user-guide/crm",
              "user-guide/creative",
              "user-guide/performance",
              "user-guide/faq"
            ]
          },
          {
            "group": "Playbooks",
            "icon": "compass",
            "pages": [
              "playbooks/connect-emma"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@agentweb.pro"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open AgentWeb",
      "href": "https://app.agentweb.pro"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/agentwebpro",
      "linkedin": "https://www.linkedin.com/company/agentweb-pro/"
    }
  }
}
