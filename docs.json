{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Emma",
  "description": "AgentWeb Documentation",
  "colors": {
    "primary": "#7A6999",
    "light": "#ECAC5F",
    "dark": "#1B2549"
  },
  "favicon": "/favicon.png",
  "logo": {
    "light": "/logo/emma-logo.webp",
    "dark": "/logo/emma-logo-dark.webp",
    "href": "https://app.agentweb.pro"
  },
  "fonts": {
    "family": "Inter"
  },
  "appearance": {
    "default": "light"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "User Guide",
        "groups": [
          {
            "group": "Onboarding",
            "icon": "rocket",
            "pages": [
              "index",
              "onboarding/brand-onboarding",
              "onboarding/organization-sharing"
            ]
          },
          {
            "group": "Reference",
            "icon": "book-open",
            "pages": [
              "user-guide/agent-mode",
              "user-guide/brand",
              "user-guide/crm",
              {
                "group": "Creative",
                "pages": [
                  "user-guide/creative",
                  "user-guide/creative/landing-pages"
                ]
              },
              "user-guide/performance",
              "user-guide/work-plans",
              {
                "group": "Integrations",
                "pages": [
                  "integrations/clickup",
                  "integrations/google-drive",
                  "integrations/gmail",
                  "integrations/google-ads",
                  "integrations/linkedin",
                  "integrations/meta",
                  "integrations/hubspot"
                ]
              },
              "user-guide/settings",
              "user-guide/faq"
            ]
          },
          {
            "group": "Playbooks",
            "icon": "compass",
            "pages": [
              "playbooks/connect-emma",
              "playbooks/linkedin-content-workflow",
              "playbooks/analytics-and-tracking"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Introduction",
            "icon": "code",
            "pages": [
              "api-reference/overview",
              "api-reference/authentication"
            ]
          },
          {
            "group": "Reference",
            "icon": "wrench",
            "pages": [
              "api-reference/emma-tools",
              "api-reference/webhooks"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@agentweb.pro"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open App",
      "href": "https://app.agentweb.pro"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity"
    ]
  },
  "redirects": [
    {
      "source": "/playbooks/landing-pages",
      "destination": "/user-guide/creative/landing-pages",
      "permanent": true
    }
  ],
  "footer": {
    "socials": {
      "linkedin": "https://linkedin.com/company/agentweb"
    }
  }
}
